# Resend — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="Golf Sol Ireland <notifications@yourdomain.com>"
RESEND_NOTIFICATION_TO=internal@yourdomain.com

# Canonical public URL for links in transactional emails (hero, footer, terms).
# On Vercel, VERCEL_URL is set per deployment; override with production domain:
SITE_URL=https://golfsolirl.com

# Supabase — browser (Vite prefix required)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...anon...

# Supabase — server (enquiry logging + Resend magic links; service role — never expose to client)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Optional: extra origins allowed for /auth/callback (comma-separated), e.g. preview deploys
# MAGIC_LINK_REDIRECT_ORIGINS=https://branch.vercel.app,https://staging.example.com

# Optional: throttle POST /api/auth/magic-link per IP (defaults: 8 requests / 15 minutes)
# MAGIC_LINK_RATE_LIMIT_PER_WINDOW=8
# MAGIC_LINK_RATE_WINDOW_MS=900000
