# Golf Sol Ireland — Master Build Plan §13
# Copy to .env.local and fill in values.

# Database (PostgreSQL — Vercel, Supabase, or Neon). If password has @ # : / ? encode as %40 %23 %3A %2F %3F.
DATABASE_URL="postgresql://..."

# Auth (next-auth). Use same origin as app in production.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="noreply@golfsolireland.com"
EMAIL_ADMIN="info@golfsolireland.com"

# Stripe (add when ready)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Twilio WhatsApp (optional)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# App
NEXT_PUBLIC_APP_URL="https://golfsolireland.com"
NEXT_PUBLIC_SITE_URL="https://golfsolireland.com"

# Cron (balance reminder). Set in Vercel; use same value in Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=""
